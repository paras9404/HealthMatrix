FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=change-me-in-production

# Postgres (dev defaults — matches `make db-up`)
DATABASE_URL=postgresql+psycopg://localhost:5432/healthmatrix_dev

# CORS / rate limiting
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
REDIS_URL=memory://
RATELIMIT_ENABLED=true

# Meilisearch (optional — when unset, the API falls back to SQL search)
# Run a local engine with: brew services start meilisearch
# Generate a master key with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MEILI_URL=http://127.0.0.1:7700
MEILI_MASTER_KEY=
MEILI_INDEX=supplements
MEILI_AUTO_SYNC=true
